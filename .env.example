# ============================================================
# 影律通（Cinemalaw AI）环境变量配置模板
# 复制本文件为 .env 并填入实际值
# ============================================================

# ---------- 应用基础配置 ----------
APP_NAME=cinemalaw-ai
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# ---------- Elasticsearch 配置 ----------
ES_HOST=localhost
ES_PORT=9200
ES_SCHEME=http
ES_USERNAME=elastic
ES_PASSWORD=changeme
ES_INDEX_PREFIX=cinemalaw
ES_CHUNK_SIZE=500
ES_TIMEOUT=30

# ---------- Milvus 向量数据库配置 ----------
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=cinemalaw_chunks
MILVUS_DIM=1024
MILVUS_METRIC=COSINE
MILVUS_INDEX_TYPE=IVF_FLAT
MILVUS_NLIST=1024
MILVUS_NPROBE=16

# ---------- BGE-M3 Embedding 模型配置 ----------
BGE_M3_MODEL_PATH=/models/bge-m3
BGE_M3_USE_GPU=true
BGE_M3_GPU_ID=0
BGE_M3_BATCH_SIZE=32
BGE_M3_MAX_LENGTH=8192
# 若使用远程推理服务，填写服务地址
BGE_M3_ENDPOINT=
BGE_M3_USE_REMOTE=false

# ---------- BGE-Reranker 配置 ----------
RERANKER_MODEL_PATH=/models/bge-reranker-large
RERANKER_USE_GPU=true
RERANKER_GPU_ID=0
RERANKER_THRESHOLD=0.35
RERANKER_TOP_K=5
RERANKER_ENDPOINT=
RERANKER_USE_REMOTE=false

# ---------- LLM 配置 ----------
# 可选 provider: claude / deepseek
LLM_PROVIDER=claude
# Claude 配置
CLAUDE_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.1
# DeepSeek 配置
DEEPSEEK_API_KEY=sk-xxxxx
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MAX_TOKENS=4096
DEEPSEEK_TEMPERATURE=0.1

# ---------- LayoutLM 配置 ----------
LAYOUTLM_MODEL_PATH=/models/layoutlm-v3
LAYOUTLM_USE_GPU=true
LAYOUTLM_GPU_ID=0
LAYOUTLM_ENDPOINT=
LAYOUTLM_USE_REMOTE=false

# ---------- RAGAS 评估配置 ----------
RAGAS_JUDGE_LLM=claude
RAGAS_EVAL_BATCH_SIZE=10

# ---------- 文档处理配置 ----------
MAX_UPLOAD_SIZE_MB=50
CHUNK_SIZE_TOKENS=600
CHUNK_OVERLAP_TOKENS=120
SUPPORTED_FORMATS=pdf,docx,png,jpg,jpeg,tiff

# ---------- Redis 配置（可选，用于缓存和队列）----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ---------- 对象存储配置（可选）----------
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=cinemalaw-documents
S3_REGION=cn-beijing
